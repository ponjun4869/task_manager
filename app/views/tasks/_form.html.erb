<% if @task.errors.any? %>
  <div class="alert alert-danger">
    <h2 class="h6"><%= @task.errors.count %>件のエラーがあります</h2>

    <ul class="mb-0">
      <% @task.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @task do |f| %>

  <div class="mb-3">
    <%= f.label :title, "タイトル", class: "form-label" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :content, "内容", class: "form-label" %>
    <%= f.text_area :content, rows: 6, class: "form-control" %>
  </div>

  <div class="mb-4">
    <%= f.label :status, "ステータス", class: "form-label" %>
    <%= f.select :status, Task.status_options, {}, class: "form-select" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "戻る", tasks_path, class: "btn btn-outline-secondary" %>
  </div>

<% end %>
