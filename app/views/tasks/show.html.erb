<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">タスク詳細</h1>
        <p class="text-body-secondary mb-0">タスクの内容を確認できます。</p>
      </div>

      <div class="d-flex gap-2">
        <span class="badge <%= @task.status_badge_class %>"><%= @task.status_label %></span>
        <span class="badge <%= @task.priority_badge_class %>"><%= @task.priority_label %></span>
      </div>
    </div>

    <div class="border rounded p-4 mb-3">
      <dl class="mb-0">
        <dt class="text-body-secondary">タイトル</dt>
        <dd class="fs-5 fw-semibold mb-4"><%= @task.title %></dd>

        <dt class="text-body-secondary">内容</dt>
        <dd class="mb-4"><%= simple_format(@task.content) %></dd>

        <dt class="text-body-secondary">期限日</dt>
        <dd class="mb-0"><%= @task.deadline&.strftime("%Y/%m/%d") || "未設定" %></dd>
      </dl>
    </div>

    <% if @task.deadline %>
      <div class="border rounded p-4 mb-3">
        <h2 class="h5 mb-3">期限日の東京の天気予報</h2>

        <% if @weather_forecast %>
          <dl class="row mb-2">
            <dt class="col-sm-4 text-body-secondary">天気</dt>
            <dd class="col-sm-8"><%= @weather_forecast[:weather_description] %></dd>

            <dt class="col-sm-4 text-body-secondary">最高気温</dt>
            <dd class="col-sm-8"><%= @weather_forecast[:maximum_temperature] %>℃</dd>

            <dt class="col-sm-4 text-body-secondary">最低気温</dt>
            <dd class="col-sm-8 mb-0"><%= @weather_forecast[:minimum_temperature] %>℃</dd>
          </dl>
        <% elsif @weather_forecast_error %>
          <p class="text-danger mb-2">天気予報を取得できませんでした。時間をおいて再度お試しください。</p>
        <% else %>
          <p class="text-body-secondary mb-2">この期限日は天気予報の対象期間外です。</p>
        <% end %>

        <p class="small text-body-secondary mb-0">
          天気データ：<%= link_to "Open-Meteo", "https://open-meteo.com/", target: "_blank", rel: "noopener noreferrer" %>
        </p>
      </div>
    <% end %>

    <div class="d-flex gap-2">
      <%= link_to "編集", edit_task_path(@task), class: "btn btn-primary" %>
      <%= link_to "一覧へ戻る", tasks_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
</div>
