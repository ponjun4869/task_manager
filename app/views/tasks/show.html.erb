<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">タスク詳細</h1>
        <p class="text-body-secondary mb-0">タスクの内容を確認できます。</p>
      </div>

      <span class="badge <%= @task.status_badge_class %>"><%= @task.status_label %></span>
    </div>

    <div class="border rounded p-4 mb-3">
      <dl class="mb-0">
        <dt class="text-body-secondary">タイトル</dt>
        <dd class="fs-5 fw-semibold mb-4"><%= @task.title %></dd>

        <dt class="text-body-secondary">内容</dt>
        <dd class="mb-0"><%= simple_format(@task.content) %></dd>
      </dl>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "編集", edit_task_path(@task), class: "btn btn-primary" %>
      <%= link_to "一覧へ戻る", tasks_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
</div>
