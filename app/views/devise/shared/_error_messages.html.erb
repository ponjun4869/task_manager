<%# Deviseのフォームで発生した入力エラーをまとめて表示する %>
<% if resource.errors.any? %>
  <div class="alert alert-danger">
    <p class="fw-semibold mb-2">入力内容を確認してください</p>

    <ul class="mb-0">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
